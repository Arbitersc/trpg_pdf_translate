# ============================================================
# TRPG PDF Translator - Frontend Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values
# Do not commit .env files containing actual API keys to version control
#

# ============================================================
# SiliconFlow API Configuration
# ============================================================
# API Key for SiliconFlow service (required for translation features)
SILICONFLOW_API_KEY=your_api_key_here

# Base URL for SiliconFlow API
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Model to use for translation
SILICONFLOW_MODEL=Pro/moonshotai/Kimi-K2.5

# Request timeout in seconds
SILICONFLOW_TIMEOUT=300

# ============================================================
# OpenAI API Configuration (Optional)
# ============================================================
# Uncomment and configure if using OpenAI API
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# PDF Parser Configuration
# ============================================================
# Parser type: mineru, pdfplumber, pymupdf
PDF_PARSER_TYPE=mineru
PARSER_TIMEOUT=300

# ============================================================
# MinerU API Configuration
# ============================================================
# MinerU API Token for PDF parsing
MINERU_API_TOKEN=your_mineru_token_here

# MinerU API URL
MINERU_API_URL=https://mineru.net/api/v4

# Model version for MinerU VLM
MINERU_MODEL_VERSION=vlm

# Request timeout in seconds
MINERU_TIMEOUT=300

# Poll interval in seconds for async operations
MINERU_POLL_INTERVAL=5

# ============================================================
# Translation Default Settings
# ============================================================
# Default source language
DEFAULT_SOURCE_LANGUAGE=English

# Default target language
DEFAULT_TARGET_LANGUAGE=中文

# Default translation window size
TRANSLATION_WINDOW_SIZE=30

# Default translation overlap ratio
TRANSLATION_OVERLAP_RATIO=0.5

# ============================================================
# Output Settings
# ============================================================
# Default output format: text, markdown, json
DEFAULT_OUTPUT_FORMAT=markdown

# Create backup when overwriting files
CREATE_BACKUP=true

# Add timestamp to output filenames
TIMESTAMP_FILES=true
